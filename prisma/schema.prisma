generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ⚠️ IMPORTANTE: El datasource provider es reemplazado dinámicamente por setup.js
// según el valor de DATABASE_PROVIDER en .env (sqlite o postgresql)
// Para cambiar: edita .env y ejecuta: npm run db:dev o npm run db:prod:deploy

// Enums reemplazados con String para compatibilidad SQLite/PostgreSQL
// Validación en capa de servicio (lib/validations.ts)

model Usuario {
  id            Int        @id @default(autoincrement())
  nombre        String
  email         String     @unique
  password      String
  rol           String     @default("ciudadano")  // 'admin' | 'fundacion' | 'donante' | 'ciudadano' | 'pendiente'
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt
  donaciones    Donacion[] @relation("Donante")
  organizacion  Organizacion?

  @@index([email])
  @@index([rol])
}

model Organizacion {
  id            Int              @id @default(autoincrement())
  nombre        String
  tipo          String           // 'ong' | 'fundacion' | 'comedor_comunitario' | 'otro'
  nit           String           @unique
  direccion     String
  ciudad        String
  telefono      String
  email         String
  descripcion   String
  verificada    Boolean          @default(false)
  estado        String           @default("pendiente")  // 'pendiente' | 'aprobada' | 'rechazada'
  usuarioId     Int              @unique
  usuario       Usuario          @relation(fields: [usuarioId], references: [id])
  motivoRechazo String?
  creadoEn      DateTime         @default(now())
  actualizadoEn DateTime         @updatedAt
  documentos    Documento[]
  solicitudes   Solicitud[]

  @@index([verificada])
  @@index([estado])
}

model Documento {
  id             Int           @id @default(autoincrement())
  organizacionId Int
  organizacion   Organizacion  @relation(fields: [organizacionId], references: [id])
  tipo           String        // 'rut' | 'camara_comercio' | 'foto'
  nombreOriginal String
  ruta           String
  mimeType       String
  tamano         Int
  creadoEn       DateTime      @default(now())

  @@index([organizacionId])
}

model Solicitud {
  id             Int             @id @default(autoincrement())
  organizacionId Int
  organizacion   Organizacion    @relation(fields: [organizacionId], references: [id])
  titulo         String
  descripcion    String
  tipo           String          // 'alimento' | 'producto'
  cantidad       String
  urgencia       String          @default("normal")  // 'baja' | 'normal' | 'alta' | 'critica'
  estado         String          @default("activa")  // 'activa' | 'cubierta' | 'cancelada' | 'vencida'
  ciudad         String
  creadoEn       DateTime        @default(now())
  actualizadoEn  DateTime        @updatedAt
  donaciones     Donacion[]

  @@index([estado])
  @@index([tipo])
  @@index([organizacionId])
}

model Donacion {
  id            Int            @id @default(autoincrement())
  donanteId     Int
  donante       Usuario        @relation("Donante", fields: [donanteId], references: [id])
  solicitudId   Int?
  solicitud     Solicitud?     @relation(fields: [solicitudId], references: [id])
  tipo          String         // 'alimento' | 'producto' | 'dinero'
  descripcion   String
  cantidad      String
  estado        String         @default("pendiente")  // 'pendiente' | 'confirmada' | 'entregada' | 'cancelada'
  creadoEn      DateTime       @default(now())
  actualizadoEn DateTime       @updatedAt

  @@index([donanteId])
  @@index([estado])
  @@index([solicitudId])
}

model Contacto {
  id       Int      @id @default(autoincrement())
  nombre   String
  email    String
  mensaje  String
  creadoEn DateTime @default(now())
}
